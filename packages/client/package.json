{
  "name": "@dbun/client",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "fmt": "oxfmt src",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "bun test"
  },
  "dependencies": {
    "@dbun/types": "workspace:*",
    "@dbun/rest": "workspace:*",
    "@dbun/ws": "workspace:*",
    "@dbun/cache": "workspace:*",
    "@dbun/structures": "workspace:*",
    "@dbun/interactions": "workspace:*",
    "@dbun/observability": "workspace:*"
  },
  "peerDependencies": {
    "@dbun/ipc": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@dbun/ipc": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "@types/bun": "catalog:"
  }
}
